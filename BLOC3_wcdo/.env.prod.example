APP_NAME=Wacdo
APP_ENV=production
APP_KEY=                          # Générer avec : php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://wacdo.stark.a3n.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_TIMEZONE=Europe/Paris

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=wacdo
DB_USERNAME=wacdo
DB_PASSWORD=CHANGE_MOI_MOT_DE_PASSE_FORT

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
