        </mxCell>
        <mxCell id="sections_menu" value="&lt;b&gt;sections_menu&lt;/b&gt;&lt;hr&gt;PK id_section_menu SERIAL&lt;br&gt;FK id_menu INT NOT NULL&lt;br&gt;nom VARCHAR(100) NOT NULL&lt;br&gt;obligatoire BOOLEAN DEFAULT true&lt;br&gt;quantite_min INTEGER DEFAULT 1&lt;br&gt;quantite_max INTEGER DEFAULT 1&lt;br&gt;CHECK quantite_min &amp;gt;= 0&lt;br&gt;CHECK quantite_max &amp;gt;= quantite_min" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff0c8;strokeColor=#b7791f;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
