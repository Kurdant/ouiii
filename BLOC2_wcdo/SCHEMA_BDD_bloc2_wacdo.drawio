        <mxCell id="utilisateurs" value="&lt;b&gt;utilisateurs&lt;/b&gt;&lt;hr&gt;PK id_utilisateur SERIAL&lt;br&gt;FK id_role INT NOT NULL&lt;br&gt;identifiant VARCHAR(100) UNIQUE NOT NULL&lt;br&gt;mot_de_passe_hash VARCHAR(255) NOT NULL&lt;br&gt;nom VARCHAR(100) NOT NULL&lt;br&gt;prenom VARCHAR(100) NOT NULL&lt;br&gt;actif BOOLEAN DEFAULT true&lt;br&gt;date_creation TIMESTAMP NOT NULL&lt;br&gt;date_modification TIMESTAMP NULL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dceeff;strokeColor=#2f6fa3;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
