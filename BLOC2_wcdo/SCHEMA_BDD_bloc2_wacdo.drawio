        <mxCell id="options_menu" value="&lt;b&gt;options_menu&lt;/b&gt;&lt;hr&gt;PK id_option_menu SERIAL&lt;br&gt;FK id_section_menu INT NOT NULL&lt;br&gt;FK id_produit INT NOT NULL&lt;br&gt;supplement_prix NUMERIC(10,2) DEFAULT 0 CHECK &amp;gt;= 0&lt;br&gt;actif BOOLEAN DEFAULT true&lt;br&gt;UNIQUE (id_section_menu, id_produit)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff0c8;strokeColor=#b7791f;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="860" y="795" width="320" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="commandes" value="&lt;b&gt;commandes&lt;/b&gt;&lt;hr&gt;PK id_commande SERIAL&lt;br&gt;numero_retrait VARCHAR(30) NOT NULL&lt;br&gt;source VARCHAR(20) CHECK IN ('api','back_office')&lt;br&gt;type_service VARCHAR(20) CHECK IN ('sur_place','a_emporter')&lt;br&gt;statut VARCHAR(20) CHECK IN ('a_preparer','preparee','livree')&lt;br&gt;total NUMERIC(10,2) CHECK total &amp;gt;= 0&lt;br&gt;date_commande TIMESTAMP NOT NULL&lt;br&gt;date_heure_retrait_prevue TIMESTAMP NULL&lt;br&gt;FK id_utilisateur_auteur INT NULL&lt;br&gt;date_preparation TIMESTAMP NULL&lt;br&gt;date_livraison TIMESTAMP NULL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dff1e2;strokeColor=#3f8449;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="1290" y="145" width="490" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="lignes_commande" value="&lt;b&gt;lignes_commande&lt;/b&gt;&lt;hr&gt;PK id_ligne_commande SERIAL&lt;br&gt;FK id_commande INT NOT NULL&lt;br&gt;type_ligne VARCHAR(20) CHECK IN ('produit','menu')&lt;br&gt;FK id_produit INT NULL&lt;br&gt;FK id_menu INT NULL&lt;br&gt;libelle_article VARCHAR(150) NOT NULL&lt;br&gt;quantite INTEGER CHECK quantite &amp;gt; 0&lt;br&gt;prix_unitaire_applique NUMERIC(10,2) CHECK &amp;gt;= 0&lt;br&gt;sous_total NUMERIC(10,2) CHECK &amp;gt;= 0&lt;br&gt;XOR id_produit / id_menu" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dff1e2;strokeColor=#3f8449;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="1290" y="540" width="490" height="285" as="geometry"/>
        </mxCell>
        <mxCell id="choix_ligne_commande" value="&lt;b&gt;choix_ligne_commande&lt;/b&gt;&lt;hr&gt;PK id_choix_ligne_commande SERIAL&lt;br&gt;FK id_ligne_commande INT NOT NULL&lt;br&gt;FK id_produit INT NOT NULL&lt;br&gt;nom_section VARCHAR(100) NOT NULL&lt;br&gt;libelle_produit VARCHAR(150) NOT NULL&lt;br&gt;prix_supplement_applique NUMERIC(10,2) DEFAULT 0 CHECK &amp;gt;= 0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dff1e2;strokeColor=#3f8449;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="1290" y="890" width="490" height="185" as="geometry"/>
        </mxCell>

        <mxCell id="traces_actions" value="&lt;b&gt;traces_actions&lt;/b&gt;&lt;hr&gt;PK id_trace SERIAL&lt;br&gt;FK id_utilisateur INT NULL&lt;br&gt;action VARCHAR(100) NOT NULL&lt;br&gt;table_cible VARCHAR(100) NOT NULL&lt;br&gt;id_cible INT NULL&lt;br&gt;date_action TIMESTAMP NOT NULL&lt;br&gt;details TEXT NULL&lt;br&gt;&lt;i&gt;table_cible/id_cible : pas de FK polymorphe stricte&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#efe3f7;strokeColor=#7b5aa6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="70" y="805" width="300" height="205" as="geometry"/>
        </mxCell>

        <mxCell id="constraints" value="&lt;b&gt;Contraintes principales visibles&lt;/b&gt;&lt;hr&gt;CHECK valeurs controlees : source ('api','back_office'), type_service ('sur_place','a_emporter'), statut ('a_preparer','preparee','livree'), type_ligne ('produit','menu').&lt;br&gt;XOR lignes_commande : une ligne reference soit un produit, soit un menu, jamais les deux.&lt;br&gt;Prix, supplements et totaux &amp;gt;= 0 ; quantite &amp;gt; 0 ; quantite_min &amp;gt;= 0 ; quantite_max &amp;gt;= quantite_min.&lt;br&gt;numero_retrait : numero du chevalet, non genere par la BDD.&lt;br&gt;source = api =&amp;gt; auteur NULL ; source = back_office =&amp;gt; auteur requis.&lt;br&gt;Suppression physique evitee : actif/disponible pour desactivation ou archivage.&lt;br&gt;Modele volontairement simple : pas de clients, paiements, stocks, sessions, tables statuts_commande ou sources_commande." style="shape=note;whiteSpace=wrap;html=1;size=18;verticalAlign=top;align=left;spacingTop=8;spacingLeft=10;fillColor=#fff8cc;strokeColor=#c7a329;fontFamily=Helvetica;fontSize=12;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="440" y="1140" width="1380" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;Legende&lt;/b&gt;&lt;br&gt;PK = cle primaire&lt;br&gt;FK = cle etrangere&lt;br&gt;NULL = reference optionnelle&lt;br&gt;1,N / 0,N = cardinalite cote parent" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
