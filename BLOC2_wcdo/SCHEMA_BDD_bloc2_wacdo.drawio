        <mxCell id="produits" value="&lt;b&gt;produits&lt;/b&gt;&lt;hr&gt;PK id_produit SERIAL&lt;br&gt;FK id_categorie INT NOT NULL&lt;br&gt;nom VARCHAR(150) NOT NULL&lt;br&gt;description TEXT NOT NULL&lt;br&gt;prix NUMERIC(10,2) CHECK prix &amp;gt;= 0&lt;br&gt;image VARCHAR(255) NOT NULL&lt;br&gt;disponible BOOLEAN DEFAULT true&lt;br&gt;actif BOOLEAN DEFAULT true&lt;br&gt;date_creation TIMESTAMP NOT NULL&lt;br&gt;date_modification TIMESTAMP NULL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffead6;strokeColor=#c56f1a;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
