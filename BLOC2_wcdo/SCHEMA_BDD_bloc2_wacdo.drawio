        <mxCell id="roles" value="&lt;b&gt;roles&lt;/b&gt;&lt;hr&gt;PK id_role SERIAL&lt;br&gt;libelle VARCHAR(50) UNIQUE NOT NULL&lt;br&gt;description VARCHAR(255) NULL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dceeff;strokeColor=#2f6fa3;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Helvetica;fontSize=11;fontColor=#172033;" vertex="1" parent="1">
